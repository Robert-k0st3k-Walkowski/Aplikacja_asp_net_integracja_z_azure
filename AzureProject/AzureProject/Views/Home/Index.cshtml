<!--Linie odpowiadające za przygotowanie wszystkich zmiennych potrzebnych w widoku-->
@using AzureProject.Models
@{
    ViewData["Title"] = "Car Database";
    var formCar = ViewBag.FormCar as Car ?? new Car();
    var cars = ViewBag.Cars as IEnumerable<Car> ?? new List<Car>();
    var readContainer = (string)(ViewBag.ReadContainer ?? "EuropeanCars");
    var editContainer = (string)(ViewBag.EditContainer ?? "EuropeanCars");
    var status = (string)(ViewBag.StatusMessage ?? "");
    var analysis = ViewBag.Analysis as CarAnalysisResult;
}
@{
    var bodyTypes = new List<SelectListItem>
    {
        new("Kombi","Kombi"),
        new("Sedan","Sedan"),
        new("Hatchback","Hatchback"),
        new("SUV","SUV"),
        new("Coupe","Coupe"),
        new("Van","Van"),
        new("Kabriolet","Kabriolet"),
    };
    var selectedBody = formCar.RodzajNadwozia ?? "";
}

<link rel="stylesheet" href="~/css/car-manager.css" />

<div class="container-fluid">
  <div class="row">
    <aside class="col-lg-4 p-4 left-panel">
      <div class="panel-card">
        <div class="section-title">EDYCJA DOKUMENTU:</div>

        <form id="carForm" method="post" enctype="multipart/form-data" class="mb-3">
            @Html.AntiForgeryToken()
            
            <div class="mb-3">
              <div class="muted-label">Kolekcja (tworzenie / edycja):</div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="editContainer" id="eu" value="EuropeanCars" @(editContainer=="EuropeanCars"?"checked":"") />
                <label class="form-check-label" for="eu">Europejskie</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="editContainer" id="us" value="AmericanCars" @(editContainer=="AmericanCars"?"checked":"") />
                <label class="form-check-label" for="us">Amerykańskie</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="editContainer" id="asia" value="AsianCars" @(editContainer=="AsianCars"?"checked":"") />
                <label class="form-check-label" for="asia">Azjatyckie</label>
              </div>
            </div>
            
            <div class="row g-2 mb-3">
              <div class="col-6">
                <label class="muted-label">Marka:</label>
                <input id="MarkaInput" name="Marka" value="@formCar.Marka" class="form-control" placeholder="Marka" autocomplete="off" />
              </div>
              <div class="col-6">
                <label class="muted-label">Model:</label>
                <input id="ModelInput" name="Model" value="@formCar.Model" class="form-control" placeholder="Model" list="modelSuggestions" autocomplete="off" />
                <datalist id="modelSuggestions"></datalist>
              </div>
            </div>
            
            <div class="row g-2 mb-3">
              <div class="col-4">
                <label class="muted-label">Rocznik:</label>
                <input name="Rocznik" type="number" value="@(formCar.Rocznik==0 ? 2000 : formCar.Rocznik)" class="form-control" />
              </div>
              <div class="col-4">
                <label class="muted-label">Kolor:</label>
                <input id="KolorInput" name="Kolor" value="@formCar.Kolor" class="form-control" placeholder="Kolor" />
              </div>
              <div class="col-4">
                <label class="muted-label">Nadwozie:</label>
                            @Html.DropDownList("RodzajNadwozia", new SelectList(bodyTypes, "Value", "Text", selectedBody), new { @class = "form-select", id = "NadwozieSelect" })
              </div>
            </div>
            
            <div class="mb-3">
              <label class="muted-label">Plik obrazu (opcjonalnie):</label>
              <input id="imageFileInput" type="file" name="imageFile" class="form-control" accept="image/*" />
              <input type="hidden" name="ImageFilename" id="ImageFilename" value="@formCar.ImageFilename" />
              <input type="hidden" name="ImageUri" id="ImageUri" value="@formCar.ImageUri" />
            </div>
            
            <input type="hidden" name="Id" value="@formCar.Id" />
            
            <div class="d-flex gap-2 mb-3">
              <button formaction="@Url.Action("Create")" formmethod="post" type="submit" class="btn btn-sm btn-custom">Dodaj dokument</button>
              <button formaction="@Url.Action("Update")" formmethod="post" type="submit" class="btn btn-sm btn-light">Uaktualnij dokument</button>
            </div>
        </form>

        <form asp-action="Delete" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" name="selectedId" value="@formCar.Id" />
          <input type="hidden" name="readContainer" value="@readContainer" />
          <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-sm btn-light">Usuń dokument</button>
          </div>
        </form>
      </div>
    </aside>

    <main class="col-lg-8 p-4">
      <div class="panel-card mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <div class="section-title">Kolekcja - dokumenty</div>

          <form method="get" asp-action="Index" class="d-flex align-items-center gap-2">
            <label class="muted-label mb-0">Pokaż kolekcję:</label>
            <select name="container" class="form-select form-select-sm" style="width:160px;">
              <option value="EuropeanCars">Europejskie</option>
              <option value="AmericanCars">Amerykańskie</option>
              <option value="AsianCars">Azjatyckie</option>
            </select>
            <button type="submit" class="btn btn-sm btn-outline-secondary">Pokaż</button>
          </form>

          <small class="text-muted">Format: Id, Marka, Model, Kolor, Rocznik, Nadwozie, Plik</small>
        </div>

        <div class="data-table table-responsive" style="max-height:420px; overflow:auto;">
          <table class="table table-borderless mb-0">
            <thead class="small text-muted" style="background:#efefef; position:sticky; top:0;">
              <tr>
                <th></th>
                <th>Id</th>
                <th>Marka</th>
                <th>Model</th>
                <th>Kolor</th>
                <th>Rocznik</th>
                <th>Nadwozie</th>
                <th>Plik</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var c in cars)
              {
                <tr>
                  <td>
                    <form asp-action="LoadSelected" method="post" style="display:inline;">
                      @Html.AntiForgeryToken()
                      <input type="hidden" name="selectedId" value="@c.Id" />
                      <input type="hidden" name="readContainer" value="@readContainer" />
                      <button type="submit" class="btn btn-sm btn-outline-dark">Wczytaj</button>
                    </form>
                  </td>
                  <td>@c.Id</td>
                  <td>@c.Marka</td>
                  <td>@c.Model</td>
                  <td>@c.Kolor</td>
                  <td>@c.Rocznik</td>
                  <td>@c.RodzajNadwozia</td>
                  <td>
                    @if (!string.IsNullOrWhiteSpace(c.ImageFilename))
                    {
                        if (!string.IsNullOrWhiteSpace(c.ImageUri))
                        {
                            <a href="@c.ImageUri" target="_blank">@c.ImageFilename</a>
                        }
                        else
                        {
                            <span>@c.ImageFilename</span>
                        }
                    }
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>

      <div class="panel-card mb-3">
        <div class="big-image">
          <div style="text-align:center;color:#333;">
            <div style="font-weight:700">Podgląd zdjęcia</div>
            @if (!string.IsNullOrWhiteSpace(formCar.ImageUri))
            {
                <div class="mt-3">
                  <img id="serverPreview" src="@formCar.ImageUri" alt="Car image" />
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(formCar.ImageFilename))
            {
                <div class="mt-3 small text-muted">@formCar.ImageFilename</div>
            }
            <div class="mt-3">
                <img id="livePreview" style="max-width:100%;height:auto;display:none;" alt="Car image preview" />
            </div>

            @if (analysis != null)
            {
                <div class="mt-3" style="text-align:left;">
                    <div class="section-title" style="font-size:1rem;">Wynik analizy (Computer Vision)</div>
                    <ul class="small">
                        @if (!string.IsNullOrWhiteSpace(analysis.Marka)) { <li><strong>Marka:</strong> @analysis.Marka</li> }
                        @if (!string.IsNullOrWhiteSpace(analysis.Model)) { <li><strong>Model:</strong> @analysis.Model</li> }
                        @if (!string.IsNullOrWhiteSpace(analysis.Kolor)) { <li><strong>Kolor:</strong> @analysis.Kolor</li> }
                        @if (!string.IsNullOrWhiteSpace(analysis.RodzajNadwozia)) { <li><strong>Nadwozie:</strong> @analysis.RodzajNadwozia</li> }
                        @if (analysis.Extra != null)
                        {
                            foreach (var kv in analysis.Extra)
                            {
                                <li><strong>@kv.Key:</strong> @kv.Value</li>
                            }
                        }
                    </ul>
                </div>
            }
          </div>
        </div>
      </div>
    </main>
  </div>
</div>

<script src="~/js/site.js" />